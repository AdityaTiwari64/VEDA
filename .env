# ─── LLM Provider Configuration ───────────────────────────────────────────────
# Choose: "ollama" (local) or "openrouter" (cloud)
DEFAULT_PROVIDER=openrouter

# Model name (for Ollama: llama3, mistral, phi3 etc. | for OpenRouter: mistralai/mistral-7b-instruct etc.)
DEFAULT_MODEL=arcee-ai/trinity-large-preview:free

# ─── API Keys ─────────────────────────────────────────────────────────────────
# OpenRouter API key (required if DEFAULT_PROVIDER=openrouter, or as fallback if Ollama is down)
OPENROUTER_API_KEY=

# ─── Research Agent ───────────────────────────────────────────────────────────
# OpenRouter key also used by signal_extractor.py for risk signal classification
# (same key as above — set it once)
